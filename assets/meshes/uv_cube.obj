# Unit cube centered at origin with per-face UV mapping.
# Coordinates are in [-0.5, 0.5].

v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Front (+Z)
f 5/1 6/2 7/3
f 5/1 7/3 8/4

# Back (-Z)
f 2/1 1/2 4/3
f 2/1 4/3 3/4

# Left (-X)
f 1/1 5/2 8/3
f 1/1 8/3 4/4

# Right (+X)
f 6/1 2/2 3/3
f 6/1 3/3 7/4

# Top (+Y)
f 4/1 8/2 7/3
f 4/1 7/3 3/4

# Bottom (-Y)
f 1/1 2/2 6/3
f 1/1 6/3 5/4
